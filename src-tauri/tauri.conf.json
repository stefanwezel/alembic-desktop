{
  "$schema": "https://raw.githubusercontent.com/nicklasbekkevold/tauri-schema/refs/heads/v2/schema.json",
  "productName": "Alembic",
  "version": "0.1.0",
  "identifier": "com.alembic.app",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "fuser -k 8080/tcp 2>/dev/null; fuser -k 3001/tcp 2>/dev/null; python3 -m http.server 8080 --directory frontend",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
      "windows": [
      {
        "title": "Alembic",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3001; img-src 'self' blob: http://localhost:3001; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/alembic-api"
    ]
  }
}
